\u044c \\u0430\\u0432\\u0442\\u043e\\u043c\\u043e\\u0431\\u0438\\u043b\\u0438. \\u0448\\u043a\\u043e\\u043b\\u0430 \\u043d\\u0430 \\u0434\\u0432\\u0435\\u043d\\u0430\\u0434\\u0446\\u0430\\u0442\\u044c50 \\u043c\\u0435\\u0441\\u0442 \\u0438 \\u0434\\u0435\\u0442\\u0441\\u043a\\u0438\\u0439 \\u0441\\u0430\\u0434 \\u043d\\u0430 \\u0442\\u0440\\u043850 \\u043c\\u0435\\u0441\\u0442 \\u043e\\u0442\\u043a\\u0440\\u043e\\u044e\\u0442\\u0441\\u044f \\u043e\\u0434\\u043d\\u043e\\u0432\\u0440\\u0435\\u043c\\u0435\\u043d\\u043d\\u043e \\u0441 \\u0437\\u0430\\u0441\\u0435\\u043b\\u0435\\u043d\\u0438\\u0435\\u043c \\u043f\\u0435\\u0440\\u0432\\u043e\\u0439 \\u043e\\u0447\\u0435\\u0440\\u0435\\u0434\\u0438, \\u044d\\u0442\\u043e \\u0437\\u043d\\u0430\\u0447\\u0438\\u0442, \\u0447\\u0442\\u043e \\u0436\\u0438\\u0442\\u0435\\u043b\\u0438 \\u043f\\u0440\\u043e\\u0435\\u043a\\u0442\\u0430 \\u0441\\u043c\\u043e\\u0433\\u0443\\u0442 \\u043e\\u0442\\u0434\\u0430\\u0442\\u044c \\u0441\\u0432\\u043e\\u0438\\u0445 \\u0434\\u0435\\u0442\\u0435\\u0439 \\u0432 \\u043d\\u043e\\u0432\\u044b\\u0435 \\u043e\\u0431\\u0440\\u0430\\u0437\\u043e\\u0432\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u044b\\u0435 \\u0443\\u0447\\u0440\\u0435\\u0436\\u0434\\u0435\\u043d\\u0438\\u044f \\u043d\\u0430 \\u0442\\u0435\\u0440\\u0440\\u0438\\u0442\\u043e\\u0440\\u0438\\u0438 \\u043a\\u0432\\u0430\\u0440\\u0442\\u0430\\u043b\\u0430. , \\u0432\\u043e \\u0434\\u0432\\u043e\\u0440\\u0430\\u0445 \\u043f\\u0440\\u0438\\u044f\\u0442\\u043d\\u043e \\u043e\\u0442\\u0434\\u044b\\u0445\\u0430\\u0442\\u044c, \\u0437\\u043d\\u0430\\u043a\\u043e\\u043c\\u0438\\u0442\\u044c\\u0441\\u044f \\u0441 \\u0441\\u043e\\u0441\\u0435\\u0434\\u044f\\u043c\\u0438 \\u0438 \\u0434\\u0430\\u0436\\u0435 \\u0437\\u0430\\u043d\\u0438\\u043c\\u0430\\u0442\\u044c\\u0441\\u044f \\u0439\\u043e\\u0433\\u043e\\u0439, \\u0430 \\u0434\\u043b\\u044f \\u0434\\u0435\\u0442\\u0435\\u0439 \\u043c\\u044b \\u043f\\u043e\\u0441\\u0442\\u0440\\u043e\\u0438\\u043c \\u0434\\u0435\\u0442\\u0441\\u043a\\u0438\\u0435 \\u043f\\u043b\\u043e\\u0449\\u0430\\u0434\\u043a\\u0438. \\u0440\\u044f\\u0434\\u043e\\u043c \\u043f\\u043e\\u044f\\u0432\\u044f\\u0442\\u0441\\u044f \\u0441\\u043e\\u0432\\u0440\\u0435\\u043c\\u0435\\u043d\\u043d\\u044b\\u0435 \\u0441\\u043f\\u043e\\u0440\\u0442\\u0438\\u0432\\u043d\\u044b\\u0435 \\u043f\\u043b\\u043e\\u0449\\u0430\\u0434\\u043a\\u0438. \\u043d\\u0430 \\u043f\\u0435\\u0440\\u0432\\u044b\\u0445 \\u044d\\u0442\\u0430\\u0436\\u0430\\u0445 \\u0434\\u043e\\u043c\\u043e\\u0432 \\u043e\\u0442\\u043a\\u0440\\u043e\\u044e\\u0442\\u0441\\u044f \\u043c\\u0430\\u0433\\u0430\\u0437\\u0438\\u043d\\u044b, \\u043a\\u0430\\u0444\\u0435 \\u0438 \\u0434\\u0440\\u0443\\u0433\\u0438\\u0435 \\u0441\\u0435\\u0440\\u0432\\u0438\\u0441\\u044b. \\u0447\\u0435\\u0440\\u0435\\u0437 \\u0432\\u0435\\u0441\\u044c \\u0436\\u0438\\u043b\\u043e\\u0439 \\u0440\\u0430\\u0439\\u043e\\u043d \\u043f\\u0440\\u043e\\u0442\\u044f\\u043d\\u0435\\u0442\\u0441\\u044f \\u0448\\u0438\\u0440\\u043e\\u043a\\u0438\\u0439 \\u043f\\u0435\\u0448\\u0435\\u0445\\u043e\\u0434\\u043d\\u044b\\u0439 \\u0431\\u0443\\u043b\\u044c\\u0432\\u0430\\u0440 \\u0434\\u043b\\u044f \\u043f\\u0440\\u043e\\u0433\\u0443\\u043b\\u043e\\u043a \\u0438 \\u0441\\u043f\\u043e\\u0440\\u0442\\u0430. , \\u0440\\u044f\\u0434\\u043e\\u043c \\u0441 \\u00ab\\u0432\\u0438\\u0442\\u0435\\u0431\\u0441\\u043a\\u0438\\u043c \\u043f\\u0430\\u0440\\u043a\\u043e\\u043c\\u00bb \\u0435\\u0441\\u0442\\u044c \\u0432\\u0441\\u0451 \\u0434\\u043b\\u044f \\u043a\\u043e\\u043c\\u0444\\u043e\\u0440\\u0442\\u043d\\u043e\\u0439 \\u0436\\u0438\\u0437\\u043d\\u0438: \\u043c\\u0430\\u0433\\u0430\\u0437\\u0438\\u043d\\u044b, \\u0442\\u043e\\u0440\\u0433\\u043e\\u0432\\u044b\\u0435 \\u0446\\u0435\\u043d\\u0442\\u0440\\u044b, \\u0444\\u0438\\u0442\\u043d\\u0435\\u0441-\\u043a\\u043b\\u0443\\u0431\\u044b, \\u043a\\u0430\\u0444\\u0435 \\u0438 \\u0440\\u0435\\u0441\\u0442\\u043e\\u0440\\u0430\\u043d\\u044b, \\u0430 \\u0435\\u0449\\u0451 \\u0434\\u0435\\u0442\\u0441\\u043a\\u0438\\u0435 \\u0441\\u0430\\u0434\\u044b, \\u0448\\u043a\\u043e\\u043b\\u044b, \\u0432\\u0443\\u0437\\u044b \\u0438 \\u043f\\u043e\\u043b\\u0438\\u043a\\u043b\\u0438\\u043d\\u0438\\u043a\\u0430. \\u0430\\u0440\\u0442\\u0438\\u043a\\u0443\\u043b - \\u043e\\u0434\\u0438\\u043d005\\u043e\\u0434\\u0438\\u043d0\\u0442\\u0440\\u0438\",\n          \"\\u043f\\u0440\\u043e\\u0434\\u0430\\u0451\\u0442\\u0441\\u044f \\u043e\\u0434\\u043d\\u043e\\u043a\\u043e\\u043c\\u043d\\u0430\\u0442\\u043d\\u0430\\u044f \\u043a\\u0432\\u0430\\u0440\\u0442\\u0438\\u0440\\u0430 \\u0432 \\u0441\\u0442\\u0440\\u043e\\u044f\\u0449\\u0435\\u043c\\u0441\\u044f \\u0434\\u043e\\u043c\\u0435 (\\u043a\\u043e\\u0440\\u043f\\u0443\\u0441 \\u043e\\u0434\\u0438\\u043d), \\u0441\\u0440\\u043e\\u043a \\u0441\\u0434\\u0430\\u0447\\u0438: i-\\u043a\\u0432. \\u0434\\u0432\\u0435 \\u0442\\u044b\\u0441\\u044f\\u0447\\u0438 \\u0434\\u0432\\u0430\\u0434\\u0446\\u0430\\u0442\\u044c \\u0432\\u043e\\u0441\\u0435\\u043c\\u044c, \\u043e\\u0431\\u0449\\u0435\\u0439 \\u043f\\u043b\\u043e\\u0449\\u0430\\u0434\\u044c\\u044e \\u0434\\u0432\\u0430\\u0434\\u0446\\u0430\\u0442\\u044c \\u0434\\u0435\\u0432\\u044f\\u0442\\u044c \\u0446\\u0435\\u043b\\u044b\\u0445 \\u0434\\u0435\\u0432\\u044f\\u0442\\u044c \\u0434\\u0435\\u0441\\u044f\\u0442\\u044b\\u0445 \\u043c\\u0435\\u0442\\u0440\\u043e\\u0432 \\u043a\\u0432\\u0430\\u0434\\u0440\\u0430\\u0442\\u043d\\u044b\\u0445, \\u043d\\u0430 \\u043e\\u0434\\u0438\\u043d\\u043e\\u0434\\u0438\\u043d \\u044d\\u0442\\u0430\\u0436\\u0435. \\u043d\\u043e\\u0432\\u044b\\u0439 \\u0436\\u0438\\u043b\\u043e\\u0439 \\u0434\\u043e\\u043c \\u043e\\u0442 \\u0437\\u0430\\u0441\\u0442\\u0440\\u043e\\u0439\\u0449\\u0438\\u043a\\u0430 \\\"\\u0441\\u0437 \\u0431\\u043b\\u044d\\u043a\\u0441\\u043c\\u0438\\u0442\\\" \\u0440\\u0430\\u0441\\u043f\\u043e\\u043b\\u043e\\u0436\\u0435\\u043d \\u043f\\u043e \\u0430\\u0434\\u0440\\u0435\\u0441\\u0443: \\u0441\\u0430\\u043d\\u043a\\u0442-\\u043f\\u0435\\u0442\\u0435\\u0440\\u0431\\u0443\\u0440\\u0433, \\u0443\\u043b\\u0438\\u0446\\u0430 \\u0444\\u0443\\u0447\\u0438\\u043a\\u0430, \\u0434. \\u043e\\u0434\\u0438\\u043d7, \\u043b\\u0438\\u0442\\u0435\\u0440\\u0430 \\u0432.\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"price_value\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 41729209.216661975,\n        \"min\": 4250000.0,\n        \"max\": 978329984.0,\n        \"num_unique_values\": 4535,\n        \"samples\": [\n          13384546.0,\n          25119000.0,\n          36705312.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"price_value_m2\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 203424.19879998287,\n        \"min\": 34090.90909090909,\n        \"max\": 2607476.6355140186,\n        \"num_unique_values\": 8754,\n        \"samples\": [\n          211403.50877192983,\n          625000.0,\n          730299.9999999999\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"price_value_m2_ls\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 203424.19879998287,\n        \"min\": 34090.90909090909,\n        \"max\": 2607476.6355140186,\n        \"num_unique_values\": 8754,\n        \"samples\": [\n          211403.50877192983,\n          625000.0,\n          730299.9999999999\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":6}]},{"cell_type":"code","source":["descriptions = df['description'].tolist()\n","prices = (df['price_value']/1e6).tolist()"],"metadata":{"id":"jUSOrMPUFVbg","executionInfo":{"status":"ok","timestamp":1773249983581,"user_tz":-180,"elapsed":64,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":7,"outputs":[]},{"cell_type":"code","source":["test_idx = np.load('/content/ruenRoSBERTa_finetuned_pooler_embeddings/test_index.npy')\n","test_prices = np.array([prices[i] for i in test_idx])\n","\n","val_idx = np.load('/content/ruenRoSBERTa_finetuned_pooler_embeddings/val_index.npy')\n","val_prices = np.array([prices[i] for i in val_idx])"],"metadata":{"id":"Iibh9qv4ZR2v","executionInfo":{"status":"ok","timestamp":1773249984104,"user_tz":-180,"elapsed":3,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":8,"outputs":[]},{"cell_type":"markdown","source":["## Эмбеддинги базовой модели"],"metadata":{"id":"2Yikd_g3VJLo"}},{"cell_type":"code","source":["sample_dict_raw = {}\n","for sample in ['train', 'test', 'val']:\n","  sample_dict_raw[sample] = torch.from_numpy(np.load(f'/content/ruenRoSBERTa_finetuned_pooler_embeddings/{sample}_embeddings.npy'))"],"metadata":{"id":"OC1y5yFVFVz_","executionInfo":{"status":"ok","timestamp":1773249986090,"user_tz":-180,"elapsed":22,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":9,"outputs":[]},{"cell_type":"code","source":["model_raw(sample_dict_raw['test']).shape"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"iCuKC3pJVIEQ","executionInfo":{"status":"ok","timestamp":1773249987675,"user_tz":-180,"elapsed":133,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"a02cb45d-943a-4281-bca1-df215eadf6ef"},"execution_count":10,"outputs":[{"output_type":"execute_result","data":{"text/plain":["torch.Size([1835, 1])"]},"metadata":{},"execution_count":10}]},{"cell_type":"code","source":["import torch.nn as nn\n","import numpy as np\n","import torch\n","from tqdm import tqdm\n","\n","def permutation_importance(model, data_array, target_array, n_iters=100, random_state=42):\n","  np.random.seed(random_state) # Use np.random.seed for numpy-based randomization\n","\n","  # Ensure data_array and target_array are torch tensors\n","  if not isinstance(data_array, torch.Tensor):\n","    data_array = torch.from_numpy(data_array).float()\n","  if not isinstance(target_array, torch.Tensor):\n","    target_array = torch.from_numpy(target_array).float().reshape(-1, 1) # Reshape to [N, 1]\n","\n","  # Set model to evaluation mode\n","  model.eval()\n","\n","  # Calculate baseline error\n","  with torch.no_grad():\n","    baseline_predictions = model(data_array)\n","    baseline_error = torch.mean((baseline_predictions - target_array)**2).item() # Using MSE as error\n","\n","  num_features = data_array.shape[1] # Number of embedding components\n","  importance_scores = np.zeros(num_features)\n","\n","  # Loop through each feature (embedding component)\n","  for i in tqdm(range(num_features)):\n","    permuted_errors = []\n","    for _ in range(n_iters):\n","      # Create a copy of the data\n","      permuted_data = data_array.clone()\n","\n","      # Permute the i-th column\n","      permuted_data[:, i] = permuted_data[np.random.permutation(len(permuted_data)), i]\n","\n","      # Calculate error with permuted data\n","      with torch.no_grad():\n","        permuted_predictions = model(permuted_data)\n","        permuted_error = torch.mean((permuted_predictions - target_array)**2).item()\n","      permuted_errors.append(permuted_error)\n","\n","    # Calculate average permuted error and importance score\n","    avg_permuted_error = np.mean(permuted_errors)\n","    importance_scores[i] = avg_permuted_error - baseline_error\n","\n","  return importance_scores"],"metadata":{"id":"ol6kAXY2VIBi","executionInfo":{"status":"ok","timestamp":1773249992259,"user_tz":-180,"elapsed":20,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":11,"outputs":[]},{"cell_type":"code","source":["importance_raw = permutation_importance(model_raw, sample_dict_raw['test'],test_prices, n_iters=50)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jGA271nvVH-5","executionInfo":{"status":"ok","timestamp":1773251253876,"user_tz":-180,"elapsed":1252787,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"c173b2a5-b69f-4f8a-8d5e-4c87441e7ab5"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stderr","text":["100%|██████████| 1024/1024 [20:52<00:00,  1.22s/it]\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","def plot_importance_scores(importance_scores, title='Permutation Importance', figsize=(12, 6)):\n","    plt.figure(figsize=figsize)\n","    sns.barplot(x=np.arange(len(importance_scores)), y=importance_scores)\n","    plt.title(title)\n","    plt.xlabel('Номер компоненты эмбеддингов')\n","    plt.ylabel('Importance Score (по метрике MSE)')\n","\n","    # Set x-axis ticks with a step of 10 and rotate them by 90 degrees\n","    plt.xticks(np.arange(0, len(importance_scores), 10), rotation=90)\n","\n","    plt.grid(axis='y', linestyle='--', alpha=0.7)\n","    plt.tight_layout()\n","    plt.show()\n","\n","plot_importance_scores(importance_raw)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":508},"id":"D20sbITXbC7r","executionInfo":{"status":"ok","timestamp":1773251371028,"user_tz":-180,"elapsed":6373,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"4ac651d0-c67e-4408-f315-fda93e177afc"},"execution_count":14,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["importance_raw[np.abs(importance_raw)<0.1].shape[0]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LmCMfwLLeBI2","executionInfo":{"status":"ok","timestamp":1773251383170,"user_tz":-180,"elapsed":43,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"68b4c1bf-9321-46df-dba3-7409855480aa"},"execution_count":15,"outputs":[{"output_type":"execute_result","data":{"text/plain":["515"]},"metadata":{},"execution_count":15}]},{"cell_type":"code","source":["corr_coeff = np.corrcoef(np.transpose(sample_dict_raw['test']))\n","np.abs(corr_coeff).min(), np.abs(np.tril(corr_coeff, k=-1)).max()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"VOanIO9objxg","executionInfo":{"status":"ok","timestamp":1773251418552,"user_tz":-180,"elapsed":162,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"51346054-877e-4a95-baf8-b2f770ebc5a4"},"execution_count":16,"outputs":[{"output_type":"execute_result","data":{"text/plain":["(np.float64(1.07971786517738e-06), np.float64(0.7825842774497966))"]},"metadata":{},"execution_count":16}]},{"cell_type":"code","source":["from sklearn.manifold import TSNE\n","import matplotlib.pyplot as plt\n","\n","# Initialize t-SNE with 2 components for 2D visualization\n","\n","for perpexity in [5, 10, 20, 30, 50]:\n","\n","  tsne = TSNE(n_components=2, random_state=42, perplexity=perpexity, n_iter=300)\n","\n","  # Fit t-SNE to the embeddings and transform them\n","  embeddings_2d = tsne.fit_transform(np.array(sample_dict_raw['test']))\n","\n","  labels = pd.qcut(test_prices, q=3, labels=['yellow', 'orange', 'red'])\n","\n","  print(f\"Original embeddings shape: {len(sample_dict_raw['test'])}\")\n","  print(f\"Projected embeddings shape: {embeddings_2d.shape}\")\n","\n","  # Visualize the projected embeddings\n","  plt.figure(figsize=(10, 8))\n","  plt.scatter(embeddings_2d[:, 0], embeddings_2d[:, 1], color=labels, alpha=0.7)\n","  plt.title(f't-SNE проекции эмбеддингов модели для текстов, perplexity={perpexity}')\n","  plt.xlabel('t-SNE Компонента 1')\n","  plt.ylabel('t-SNE Компонента 2')\n","  plt.grid(True)\n","  plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"573gjYqiJehA","executionInfo":{"status":"ok","timestam