7ca"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Archive:  /content/model_and_metrics_embeddings_pooler_finetuning_stage1.zip\n","  inflating: stage1/metrics_1/train_rmses.txt  \n","  inflating: stage1/metrics_1/val_losses.txt  \n","  inflating: stage1/metrics_1/train_losses.txt  \n","  inflating: stage1/metrics_1/val_rmses.txt  \n","  inflating: stage1/model_checkpoints_1/best_checkpoint_pooler.pt  \n","  inflating: stage1/model_checkpoints_1/best_checkpoint.pt  \n","Archive:  /content/model_and_metrics_embeddings_pooler_finetuning_stage2.zip\n","  inflating: stage2/metrics_1/train_losses.txt  \n","  inflating: stage2/metrics_1/val_losses.txt  \n","  inflating: stage2/metrics_1/val_rmses.txt  \n","  inflating: stage2/metrics_1/train_rmses.txt  \n","  inflating: stage2/metrics_finetuning_head_2/train_losses.txt  \n","  inflating: stage2/metrics_finetuning_head_2/val_losses.txt  \n","  inflating: stage2/metrics_finetuning_head_2/val_rmses.txt  \n","  inflating: stage2/metrics_finetuning_head_2/train_rmses.txt  \n","  inflating: stage2/model_checkpoints_1/best_checkpoint.pt  \n","  inflating: stage2/model_checkpoints_1/best_checkpoint_pooler.pt  \n","  inflating: stage2/model_checkpoints_finetuning_head_2/best_checkpoint.pt  \n","  inflating: stage2/model_checkpoints_finetuning_head_2/best_checkpoint_pooler.pt  \n"]}]},{"cell_type":"code","source":["import torch\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")"],"metadata":{"id":"hCKlxyz4Eq8w","executionInfo":{"status":"ok","timestamp":1773249941732,"user_tz":-180,"elapsed":3643,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["import torch.nn as nn\n","from collections import OrderedDict\n","# простая нейронная сеть, на вход которой подаются эмбеддинги\n","class RoSBERTRegressor_2layerhead(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","\n","        # Store the pre-trained SBERT model\n","        self.hidden_layer_neurons = 256\n","        self.activation = nn.Sigmoid()\n","        self.regression_head = nn.Sequential(\n","                      OrderedDict([\n","                          ('regression_head1', nn.Linear(1024, self.hidden_layer_neurons)),\n","                          ('aciv1', self.activation),\n","                          ('regression_head2', nn.Linear(self.hidden_layer_neurons, 1)),\n","                      ])\n","                  )\n","\n","    def forward(self, x):\n","        embeddings_x = nn.functional.normalize(x)\n","        res = self.regression_head(embeddings_x)\n","\n","        return res\n","\n","    def upload_checkpoint(self, path, device):\n","      self.regression_head.load_state_dict(torch.load(path, map_location=device))\n","\n","    def save_checkpoint(self, path):\n","      torch.save(self.regression_head.state_dict(), path)\n","      print(f'savepath: {path}')\n"],"metadata":{"id":"f2QS_ywUGfw3","executionInfo":{"status":"ok","timestamp":1773249942793,"user_tz":-180,"elapsed":2,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":4,"outputs":[]},{"cell_type":"code","source":["model_raw = RoSBERTRegressor_2layerhead()\n","\n","model_raw.upload_checkpoint('/content/stage2/model_checkpoints_finetuning_head_2/best_checkpoint.pt', device)"],"metadata":{"id":"3xCrmrdrFfsV","executionInfo":{"status":"ok","timestamp":1773249951050,"user_tz":-180,"elapsed":71,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":5,"outputs":[]},{"cell_type":"code","source":["import pandas as pd\n","import numpy as np\n","\n","# Create a Pandas DataFrame\n","df = pd.read_csv('/content/offers_data_numalphareduced.csv') # для проверки на CPU\n","\n","df.rename(columns = {'p_full_description': 'description'}, inplace=True)\n","\n","df.head()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","hei