440\\u0430\\u043c\\u043d\\u044b\\u0435 \\u0432\\u0438\\u0434\\u044b \\u043f\\u0435\\u0442\\u0435\\u0440\\u0431\\u0443\\u0440\\u0433\\u0430.\",\n          \"\\u043f\\u0440\\u043e\\u0434\\u0430\\u0451\\u0442\\u0441\\u044f \\u0434\\u0432\\u0443\\u0445\\u043a\\u043e\\u043c\\u043d\\u0430\\u0442\\u043d\\u0430\\u044f\\u043a\\u0432\\u0430\\u0440\\u0442\\u0438\\u0440\\u0430 \\u043f\\u043b\\u043e\\u0449\\u0430\\u0434\\u044c\\u044e \\u043f\\u044f\\u0442\\u044c\\u0434\\u0435\\u0441\\u044f\\u0442 \\u0434\\u0432\\u0435 \\u0446\\u0435\\u043b\\u044b\\u0445 \\u0432\\u043e\\u0441\\u0435\\u043c\\u044c\\u0434\\u0435\\u0441\\u044f\\u0442 \\u0441\\u043e\\u0442\\u044b\\u0445 \\u043a\\u0432. \\u043c \\u043d\\u0430 \\u0447\\u0435\\u0442\\u044b\\u0440\\u0435 \\u044d\\u0442\\u0430\\u0436\\u0435 \\u0434\\u0432\\u0435\\u043d\\u0430\\u0434\\u0446\\u0430\\u0442\\u044c \\u044d\\u0442\\u0430\\u0436\\u043d\\u043e\\u0433\\u043e \\u0434\\u043e\\u043c\\u0430 (\\u043a\\u043e\\u0440\\u043f\\u0443\\u0441 \\u0448\\u0435\\u0441\\u0442\\u044c, \\u0441\\u0435\\u043a\\u0446\\u0438\\u044f \\u043e\\u0434\\u0438\\u043d) \\u043f\\u0440\\u043e\\u0435\\u043a\\u0442\\u0430 \\u043f\\u0438\\u043a \\u0432\\u0438\\u0442\\u0435\\u0431\\u0441\\u043a\\u0438\\u0439 \\u043f\\u0430\\u0440\\u043a. \\u0441\\u0432\\u0435\\u0442\\u043b\\u044b\\u0439 \\u043f\\u0440\\u043e\\u0441\\u0442\\u043e\\u0440\\u043d\\u044b\\u0439 \\u043f\\u043e\\u0434\\u044a\\u0435\\u0437\\u0434 \\u043d\\u0430 \\u0443\\u0440\\u043e\\u0432\\u043d\\u0435 \\u0437\\u0435\\u043c\\u043b\\u0438, \\u0444\\u0443\\u043d\\u043a\\u0446\\u0438\\u043e\\u043d\\u0430\\u043b\\u044c\\u043d\\u0430\\u044f \\u043f\\u043b\\u0430\\u043d\\u0438\\u0440\\u043e\\u0432\\u043a\\u0430, \\u0431\\u043e\\u043b\\u044c\\u0448\\u0438\\u0435 \\u043e\\u043a\\u043d\\u0430, \\u0441 \\u043e\\u0442\\u0434\\u0435\\u043b\\u043a\\u043e\\u0439. , \\u0436\\u0438\\u043b\\u043e\\u0439 \\u043a\\u0432\\u0430\\u0440\\u0442\\u0430\\u043b \\u00ab\\u0432\\u0438\\u0442\\u0435\\u0431\\u0441\\u043a\\u0438\\u0439 \\