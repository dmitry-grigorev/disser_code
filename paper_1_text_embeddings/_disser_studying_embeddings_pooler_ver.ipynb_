at64(-0.035440968481522506),\n"," np.float64(0.01172263289241656),\n"," np.float64(0.07448613812503968),\n"," np.float64(0.05614988855949976),\n"," np.float64(0.03791284503080051),\n"," np.float64(0.05390736485455248),\n"," np.float64(-0.062220380754255615),\n"," np.float64(0.03603737385449384),\n"," np.float64(-0.05519687339860788),\n"," np.float64(0.023568851164106182),\n"," np.float64(0.04952910840318021),\n"," np.float64(-0.002451984458553561),\n"," np.float64(-0.008760023271695906),\n"," np.float64(0.02376514827690892),\n"," np.float64(-0.05505539242060596),\n"," np.float64(-0.06262110660630611),\n"," np.float64(0.07178758107869353),\n"," np.float64(0.0022446532316721455),\n"," np.float64(-0.09325273853183297),\n"," np.float64(0.02657431738878253),\n"," np.float64(-0.037245205872167834),\n"," np.float64(0.054867863947258524),\n"," np.float64(0.042184173604695514),\n"," np.float64(0.07764244631158827),\n"," np.float64(-0.04815112982204247),\n"," np.float64(0.019725495314296678),\n"," np.float64(0.014696915582338996),\n"," np.float64(0.07498148565658107),\n"," np.float64(-0.05891037181573994),\n"," np.float64(-0.05027378243851586),\n"," np.float64(0.03816063241017212),\n"," np.float64(-0.012723445392319342),\n"," np.float64(0.0124082375658402),\n"," np.float64(-0.008323007099188793),\n"," np.float64(-0.06017599140085408),\n"," np.float64(-0.031083350863260188),\n"," np.float64(0.02383550811179399),\n"," np.float64(0.05423836497155891),\n"," np.float64(-0.06880198849466967),\n"," np.float64(0.015695970470125047),\n"," np.float64(0.02282134358614256),\n"," np.float64(-0.04059463678808845)]"]},"metadata":{},"execution_count":21}]},{"cell_type":"markdown","source":["## Абляционный анализ\n","Будем случайно заменять подмножетво компонент их средними.\n","\n","Средние вычисляем на трейне"],"metadata":{"id":"qSDGe7pd1dIk"}},{"cell_type":"code","source":["train_averages = sample_dict_raw['train'].mean(axis=0)"],"metadata":{"id":"hvGkKdbD1omg","executionInfo":{"status":"ok","timestamp":1773251495533,"user_tz":-180,"elapsed":17,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":22,"outputs":[]},{"cell_type":"code","source":["import torch.nn as nn\n","import numpy as np\n","import torch\n","from tqdm import tqdm\n","\n","def ablation_study_function(model, data_array, target_array, train_averages, n_iterations=100, num_components_to_mask=100, random_state=42):\n","    np.random.seed(random_state)\n","\n","    if not isinstance(data_array, torch.Tensor):\n","        data_array = torch.from_numpy(data_array).float()\n","    if not isinstance(target_array, torch.Tensor):\n","        target_array = torch.from_numpy(target_array).float().reshape(-1, 1)\n","    if not isinstance(train_averages, torch.Tensor):\n","        train_averages = torch.from_numpy(train_averages).float()\n","\n","    model.eval()\n","\n","    num_embedding_components = data_array.shape[1]\n","    ablation_metrics = []\n","\n","\n","    curr_avg_diff, prev_avg_diff = 0, -1\n","\n","    with torch.no_grad():\n","      baseline_predictions = model(data_array)\n","      baseline_error = torch.mean((baseline_predictions - target_array)**2).item() # Using MSE as error\n","\n","    for i in tqdm(range(n_iterations)):\n","        # Create a copy of the data to modify\n","        modified_data = data_array.clone()\n","\n","        # Randomly select num_components_to_mask embedding component indices\n","        components_to_mask = np.random.choice(\n","            num_embedding_components,\n","            size=num_components_to_mask,\n","            replace=False\n","        )\n","\n","        # Replace the selected components with their average values\n","        for comp_idx in components_to_mask:\n","            modified_data[:, comp_idx] = train_averages[comp_idx]\n","\n","        # Calculate error with modified data\n","        with torch.no_grad():\n","            predictions = model(modified_data)\n","            error = torch.mean((predictions - target_array)**2).item() # Using MSE as error\n","\n","        prev_avg_diff = curr_avg_diff\n","        rel_change = np.abs(error-baseline_error)/baseline_error\n","        curr_avg_diff = rel_change if i == 0 else (rel_change+prev_avg_diff*i)/(i+1)\n","\n","\n","        ablation_metrics.append(error)\n","\n","    if (prev_avg_diff-curr_avg_diff) < 1e-4:\n","      print('Среднее сошлось!')\n","\n","    ablation_metrics = np.array(ablation_metrics)\n","    print(f'Среднее относительное изменение {(np.abs(ablation_metrics - baseline_error)/baseline_error).mean()*100: .3f}')\n","    return ablation_metrics, ablation_metrics - baseline_error, baseline_error"],"metadata":{"id":"-fx3Ym662XIn","executionInfo":{"status":"ok","timestamp":1773251498963,"user_tz":-180,"elapsed":21,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}}},"execution_count":23,"outputs":[]},{"cell_type":"code","source":["ablation_results = ablation_study_function(model_raw, sample_dict_raw['val'],val_prices, train_averages, n_iterations=200,\n","                                           num_components_to_mask=240)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"wVDE16aTuUwj","executionInfo":{"status":"ok","timestamp":1773251508786,"user_tz":-180,"elapsed":6076,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"55a6bff4-f297-4d41-c842-aa0a9a3a126b"},"execution_count":24,"outputs":[{"output_type":"stream","name":"stderr","text":["100%|██████████| 200/200 [00:06<00:00, 33.09it/s]"]},{"output_type":"stream","name":"stdout","text":["Среднее сошлось!\n","Среднее относительное изменение  5.120\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"code","source":["ablation_results[2]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vOJxJZjm-2Q6","executionInfo":{"status":"ok","timestamp":1773251510943,"user_tz":-180,"elapsed":14,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"bd5810db-2f41-4da2-d310-dd0dfe27b12a"},"execution_count":25,"outputs":[{"output_type":"execute_result","data":{"text/plain":["907.735107421875"]},"metadata":{},"execution_count":25}]},{"cell_type":"code","source":["#!rm -r '/content/ruenRoSBERTa_finetuned_pooler_embeddings'"],"metadata":{"id":"lHMc_ZXUd_HE"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["ablation_results = ablation_study_function(model_raw, sample_dict_raw['test'],test_prices, train_averages, n_iterations=200,\n","                                           num_components_to_mask=240)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"QDIQ-n_6-mc9","executionInfo":{"status":"ok","timestamp":1773251520490,"user_tz":-180,"elapsed":7774,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"233f1167-460c-4a2a-f3b7-997237ad6381"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stderr","text":["100%|██████████| 200/200 [00:07<00:00, 25.86it/s]"]},{"output_type":"stream","name":"stdout","text":["Среднее сошлось!\n","Среднее относительное изменение  4.197\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"code","source":["ablation_results[2]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"tDLBkhn9_TdR","executionInfo":{"status":"ok","timestamp":1773253950164,"user_tz":-180,"elapsed":19,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"2c47f35f-5138-4fab-af49-c2b7a6f4f07d"},"execution_count":28,"outputs":[{"output_type":"execute_result","data":{"text/plain":["1542.476318359375"]},"metadata":{},"execution_count":28}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import seaborn as sns\n","from matplotlib.ticker import PercentFormatter\n","\n","plt.figure(figsize=(10, 6))\n","plt.hist(ablation_results[1], bins=30, density=True, alpha=0.7)\n","\n","# Set y-axis to display frequency as percentages\n","plt.gca().yaxis.set_major_formatter(PercentFormatter(xmax=1))\n","\n","plt.title('Распределение дельты MSE при абляции')\n","plt.xlabel('Дельта MSE относительно значения на тестовой выборке')\n","plt.ylabel('Частота (%)')\n","plt.grid(axis='y', linestyle='--', alpha=0.7)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":607},"id":"QH6FQeR1uVvq","executionInfo":{"status":"ok","timestamp":1773251861060,"user_tz":-180,"elapsed":547,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"8cfe76f0-b520-4132-fd05-fbe9c3206fe5"},"execution_count":27,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["с= ablation_study_function(model_raw, sample_dict_raw['test'],test_prices, train_averages, n_iterations=200,\n","                                           num_components_to_mask=250)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GpC4MNDe37xe","executionInfo":{"status":"ok","timestamp":1770484405894,"user_tz":-180,"elapsed":16768,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"c709c954-9429-487b-b1b2-ee02ecd8e036"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["100%|██████████| 200/200 [00:16<00:00, 12.07it/s]"]},{"output_type":"stream","name":"stdout","text":["Среднее относительное изменение  19.389\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}]},{"cell_type":"code","source":["9"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"E5d0ohQ1E9cW","executionInfo":{"status":"ok","timestamp":1770484345372,"user_tz":-180,"elapsed":8,"user":{"displayName":"Dmitriy Grigorev","userId":"14018911779499266586"}},"outputId":"f7388a51-c4b4-4018-d2e4-3151111d7bb3"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":[